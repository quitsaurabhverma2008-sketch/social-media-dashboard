{
  "manifest_version": 3,
  "name": "Social Media Auto-Scroll",
  "version": "1.0.0",
  "description": "Auto-scroll social media feeds sync with Social Media Dashboard",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.youtube.com/*",
    "https://*.tiktok.com/*",
    "https://*.facebook.com/*",
    "https://*.x.com/*",
    "https://social-media-dashboard-quitsaurabhverma2008-9330s-projects.vercel.app/*",
    "https://social-media-dashboard-*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*",
        "https://*.youtube.com/*",
        "https://*.tiktok.com/*",
        "https://*.facebook.com/*",
        "https://*.x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://social-media-dashboard-quitsaurabhverma2008-9330s-projects.vercel.app/*",
        "https://social-media-dashboard-*.vercel.app/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Social Media Auto-Scroll",
    "default_popup": "popup.html"
  }
}
